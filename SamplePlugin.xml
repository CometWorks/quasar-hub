<?xml version="1.0"?>
<PluginData xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="GitHubPlugin">

    <!-- Stable Quasar UI plugin id. Generate once, then do not change it. -->
    <Id>00000000-0000-0000-0000-000000000000</Id>

    <!-- GitHub repository ID, owner/repo. -->
    <RepoId>todo-github-user/project-name</RepoId>

    <!-- Name shown in Quasar plugin lists. -->
    <FriendlyName>TODO Your Plugin Name</FriendlyName>

    <!-- Author shown in Quasar plugin details. -->
    <Author>TODO Author Name</Author>

    <!-- Short plugin summary. -->
    <Tooltip>TODO Short description</Tooltip>

    <!-- Longer plugin description. Keep it clear and reviewable. -->
    <Description>TODO Long description, multiple lines.

        Describe the Quasar UI pages, nav items, extension points, and any
        companion Magnetar plugins this UI talks to.

        Quasar plugins should use MudBlazor for ordinary UI controls and should
        inherit Quasar theme tokens instead of shipping a competing app shell.
    </Description>

    <!-- Quasar UI plugin manifests use this kind. -->
    <PluginKind>QuasarUiPlugin</PluginKind>

    <!-- Relative path to the plugin project in the plugin repository. -->
    <ProjectPath>src/TodoPlugin/TodoPlugin.csproj</ProjectPath>

    <!-- Relative path to the runtime package manifest in the plugin repository. -->
    <PackageManifest>quasar-plugin.json</PackageManifest>

    <!-- Optional Quasar version range supported by this plugin. -->
    <QuasarVersion>&gt;=0.1.0</QuasarVersion>

    <!-- Optional companion Magnetar plugins expected by this UI plugin.
    <CompanionPluginIds>
      <Id>GridBackups</Id>
    </CompanionPluginIds>
    -->

    <!-- Optional Quasar UI plugin dependencies.
    <DependencyIds>
      <Id>TODO ID of another Quasar UI plugin this one depends on</Id>
    </DependencyIds>
    -->

    <!-- Optional platform restriction. If omitted, the plugin loads on all platforms.
    <Platforms>Windows,Linux</Platforms>
    -->

    <!-- Hidden plugins cannot be selected directly and are intended as dependencies.
    <Hidden>false</Hidden>
    -->

    <!-- Optional automatic install/update from QuasarHub.
    <ImplicitLoading>false</ImplicitLoading>
    -->

    <!-- Current plugin version's commit hash. -->
    <Commit>TODO Git commit hash</Commit>

    <!-- Optional list of alternate versions for test/custom builds.
    <AlternateVersions>
      <Version>
        <Name>Version Name</Name>
        <Commit>Commit hash</Commit>
      </Version>
    </AlternateVersions>
    -->

</PluginData>
